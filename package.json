{
  "name": "soulguard-monorepo",
  "version": "2.0.0",
  "private": true,
  "homepage": "https://soulguard.ai",
  "license": "MIT",
  "author": "Mirascope <support@mirascope.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mirascope/soulguard.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:integration": "bun run --filter '@soulguard/core' test:integration",
    "test:e2e": "cd packages/core && docker build -f test-e2e/Dockerfile -t soulguard-e2e ../.. && bun test-e2e/run.ts",
    "test:e2e:update": "cd packages/core && docker build -f test-e2e/Dockerfile -t soulguard-e2e ../.. && bun test-e2e/run.ts --update",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint packages/*/src",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "bump-version": "bun scripts/bump-version.ts",
    "check-versions": "bun scripts/bump-version.ts --check",
    "prepare": "husky",
    "publish:all": "bun scripts/publish.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.md": [
      "oxfmt --write"
    ]
  }
}
